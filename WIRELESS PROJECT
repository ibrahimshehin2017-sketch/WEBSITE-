        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Parameters\n",
        "num_bits = 100000\n",
        "M = 4                     # PAM level (2 or 4)\n",
        "snr_db = np.arange(0, 21, 2)\n",
        "ber = []\n",
        "\n",
        "# Generate random bits\n",
        "bits = np.random.randint(0, 2, num_bits)\n",
        "\n",
        "# PAM Mapping\n",
        "def pam_modulation(bits, M):\n",
        "    k = int(np.log2(M))\n",
        "    symbols = []\n",
        "\n",
        "    for i in range(0, len(bits), k):\n",
        "        bit_group = bits[i:i+k]\n",
        "        decimal = int(\"\".join(str(b) for b in bit_group), 2)\n",
        "        symbols.append(2*decimal - (M-1))\n",
        "\n",
        "    return np.array(symbols)\n",
        "\n",
        "symbols = pam_modulation(bits, M)\n",
        "\n",
        "# Log-normal turbulence model\n",
        "def turbulence(signal):\n",
        "    sigma = 0.4\n",
        "    fading = np.exp(np.random.normal(-sigma**2/2, sigma, len(signal)))\n",
        "    return signal * fading\n",
        "\n",
        "# Monte Carlo Simulation\n",
        "for snr in snr_db:\n",
        "\n",
        "    # Channel with turbulence\n",
        "    faded_signal = turbulence(symbols)\n",
        "\n",
        "    # Noise\n",
        "    snr_linear = 10**(snr/10)\n",
        "    noise_std = np.sqrt(1/(2*snr_linear))\n",
        "    noise = noise_std * np.random.randn(len(faded_signal))\n",
        "\n",
        "    received = faded_signal + noise\n",
        "\n",
        "    # Detection\n",
        "    detected = np.round((received + (M-1)) / 2)\n",
        "    detected = np.clip(detected, 0, M-1)\n",
        "\n",
        "    # Convert symbols back to bits\n",
        "    detected_bits = []\n",
        "    for d in detected:\n",
        "        b = format(int(d), '0{}b'.format(int(np.log2(M))))\n",
        "        detected_bits.extend([int(x) for x in b])\n",
        "\n",
        "    detected_bits = np.array(detected_bits[:num_bits])\n",
        "\n",
        "    # BER Calculation\n",
        "    errors = np.sum(bits != detected_bits)\n",
        "    ber.append(errors / num_bits)\n",
        "\n",
        "# Plot BER vs SNR\n",
        "plt.semilogy(snr_db, ber, marker='o')\n",
        "plt.xlabel(\"SNR (dB)\")\n",
        "plt.ylabel(\"Bit Error Rate (BER)\")\n",
        "plt.title(\"FSO System using PAM Modulation\")\n",
        "plt.grid(True)\n",
        "plt.show()"
      ]
